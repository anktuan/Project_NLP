# ==============================================================
# Knowledge Editing Web App -- Environment Variables
# ==============================================================
# Copy file này thành .env và điền API key của bạn vào
# KHÔNG commit file .env lên Git!
# cp .env.example .env  (Linux/Mac)
# copy .env.example .env  (Windows)
# ==============================================================

# --- Gemini API (Google AI Studio) ---
# Lấy tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- OpenAI / ChatGPT API ---
# Lấy tại: https://platform.openai.com/api-keys
#OPENAI_API_KEY=your_openai_api_key_here

# --- Tavily Search API (tuỳ chọn) ---
# Lấy tại: https://app.tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# --- Cài đặt LLM mặc định để sinh câu trả lời ---
# Chọn: "gemini" | "openai" | "none"
DEFAULT_LLM_PROVIDER=gemini

# --- Checkpoint ---
# Thư mục lưu model checkpoint sau khi edit
CHECKPOINT_DIR=./checkpoints
